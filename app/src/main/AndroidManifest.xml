<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
package="ru.ltow.cube">

    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

    <application
        android:name=".App"
        android:theme="@style/AppTheme"
        android:label="@string/app_name"
        android:allowBackup="true"
        android:icon="@mipmap/cube"
        android:supportsRtl="true"
        android:fullBackupContent="@xml/backup_descriptor">

        <activity android:name=".BaseA" android:screenOrientation="portrait"/>
        <activity android:name=".Main" android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                </intent-filter>
        </activity>
        <activity android:name=".XOGL" android:screenOrientation="portrait"/>
        <activity android:name=".About" android:screenOrientation="portrait"/>
    </application>

</manifest>